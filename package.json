{
  "name": "@jurislm/judicial-mcp",
  "version": "1.4.0",
  "description": "MCP server for accessing Taiwan Judicial Yuan open data and judgments.",
  "keywords": [
    "mcp",
    "judicial",
    "open-data",
    "court",
    "taiwan"
  ],
  "homepage": "https://github.com/jurislm/judicial-mcp#readme",
  "bugs": {
    "url": "https://github.com/jurislm/judicial-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jurislm/judicial-mcp.git"
  },
  "license": "MIT",
  "author": {
    "name": "Terry Chen",
    "email": "zxtw17985321@gmail.com"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "types/index.d.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --max-warnings=0",
    "lint:fix": "eslint --fix --max-warnings=0",
    "build:types": "tsc --emitDeclarationOnly",
    "prepublishOnly": "bun run typecheck && bun run test && bun run lint && bun run build:types"
  },
  "files": [
    "src",
    "bin",
    "types",
    "README.md"
  ],
  "bin": {
    "judicial-mcp": "bin/judicial-mcp.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.6.0",
    "dotenv": "^17.0.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.9",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
